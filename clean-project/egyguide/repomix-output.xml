.home-container {
  height: calc(100vh - 80px);
  background: url('/assets/images/pyramids-bg.jpg') center/cover no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;

  // Darker sandy overlay with sunset gradient
  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      180deg,
      rgba(80, 50, 20, 0.2) 0%,      // Reduced from 0.3 to 0.2
      rgba(60, 35, 15, 0.4) 20%,     // Reduced from 0.55 to 0.4
      rgba(40, 25, 15, 0.45) 40%,    // Reduced from 0.55 to 0.45
      rgba(25, 15, 10, 0.5) 60%,     // Reduced from 0.65 to 0.5
      rgba(15, 10, 8, 0.5) 80%,      // Reduced from 0.65 to 0.5
      rgba(8, 5, 5, 0.55) 100%       // Reduced from 0.65 to 0.55
    );
    pointer-events: none;
  }

  // Additional dark vignette effect
  &::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      transparent 30%,
      rgba(0, 0, 0, 0.4) 70%,
      rgba(0, 0, 0, 0.7) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  // Sparkle effects
  .sparkles {
    position: absolute;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;

    .sparkle {
      position: absolute;
      width: 4px;
      height: 4px;
      background: #d4af37;
      border-radius: 50%;
      box-shadow: 
        0 0 10px #d4af37,
        0 0 20px #d4af37,
        0 0 30px #d4af37,
        0 0 40px #d4af37;
      animation: sparkleFloat 3s ease-in-out infinite;
      opacity: 0;
    }
  }

  .hero-content {
    text-align: center;
    color: white;
    position: relative;
    z-index: 4;
    padding: 2rem;

    .hero-title {
    font-size: 6.1rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    .line1, .line2 {
      display: block;
      background: linear-gradient(
        135deg,
        #f4e4b8 0%,
        #d4af37 25%,
        #f0d98d 50%,
        #d4af37 75%,
        #f4e4b8 100%
      );
      background-size: 200% auto;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s linear infinite;
      text-shadow: 
        0 0 30px rgba(212, 175, 55, 0.5),
        0 0 60px rgba(212, 175, 55, 0.3),
        0 0 90px rgba(212, 175, 55, 0.2);
      filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.6));
      font-family: 'Cormorant Garamond', 'Georgia', 'Palatino', serif;  // Changed to match navbar
      letter-spacing: 0.02em;
    }
  }

    .hero-subtitle {
      font-size: 1.8rem;
      margin-bottom: 3rem;
      color: rgba(220, 220, 220, 0.95);
      text-shadow: 
        0 2px 10px rgba(0, 0, 0, 0.8),
        0 0 20px rgba(212, 175, 55, 0.4);
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .cta-button {
      position: relative;
      background: linear-gradient(135deg, #d4af37 0%, #f0c850 50%, #d4af37 100%);
      background-size: 200% auto;
      color: #1a1a1a;
      border: none;
      padding: 1.3rem 3.5rem;
      font-size: 1.4rem;
      font-weight: 600;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.4s ease;
      overflow: hidden;
      box-shadow: 
        0 0 20px rgba(212, 175, 55, 0.4),
        0 5px 15px rgba(0, 0, 0, 0.3),
        inset 0 -2px 10px rgba(0, 0, 0, 0.2),
        inset 0 2px 10px rgba(255, 255, 255, 0.4);
      letter-spacing: 0.05em;

      .button-text {
        position: relative;
        z-index: 2;
      }

      .button-glow {
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(
          circle,
          rgba(255, 255, 255, 0.8) 0%,
          rgba(255, 255, 255, 0.4) 30%,
          transparent 70%
        );
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
      }

      &::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(255, 255, 255, 0.6),
          transparent
        );
        transition: left 0.6s ease;
      }

      &:hover {
        transform: translateY(-3px) scale(1.05);
        background-position: right center;
        box-shadow: 
          0 0 30px rgba(212, 175, 55, 0.7),
          0 0 60px rgba(212, 175, 55, 0.4),
          0 10px 25px rgba(0, 0, 0, 0.4),
          inset 0 -2px 10px rgba(0, 0, 0, 0.2),
          inset 0 2px 10px rgba(255, 255, 255, 0.5);
        
        &::before {
          left: 100%;
        }

        .button-glow {
          opacity: 0.6;
          animation: pulse-glow 1.5s ease-in-out infinite;
        }
      }

      &:active {
        transform: translateY(-1px) scale(1.02);
      }
    }
  }
}

// Animations
@keyframes shimmer {
  0% {
    background-position: 0% center;
  }
  100% {
    background-position: 200% center;
  }
}

@keyframes sparkleFloat {
  0%, 100% {
    opacity: 0;
    transform: translateY(0) scale(0);
  }
  20% {
    opacity: 1;
    transform: translateY(-10px) scale(1);
  }
  80% {
    opacity: 1;
    transform: translateY(-20px) scale(1);
  }
  100% {
    opacity: 0;
    transform: translateY(-30px) scale(0);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.8;
  }
}

// Responsive
@media (max-width: 768px) {
  .home-container .hero-content {
    .hero-title {
      font-size: 2.5rem;
      
      .line1, .line2 {
        font-size: 2.5rem;
      }
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .cta-button {
      padding: 1rem 2.5rem;
      font-size: 1.1rem;
    }
  }
}
