.about-container {
  min-height: calc(100vh - 80px);
  background-color: #0f0f0f;
  background-image: 
    repeating-linear-gradient(
      90deg,
      rgba(212, 175, 55, 0.03) 0px,
      transparent 1px,
      transparent 40px,
      rgba(212, 175, 55, 0.03) 41px
    ),
    repeating-linear-gradient(
      0deg,
      rgba(212, 175, 55, 0.03) 0px,
      transparent 1px,
      transparent 40px,
      rgba(212, 175, 55, 0.03) 41px
    );

  section {
    padding: 4rem 2rem;
  }

  .content-wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 3rem;
    color: #d4af37;
    text-align: center;
    margin-bottom: 3rem;
    font-weight: 400;
    position: relative;
    
    &::after {
      content: '';
      display: block;
      width: 80px;
      height: 3px;
      background: linear-gradient(90deg, transparent, #d4af37, transparent);
      margin: 1rem auto 0;
    }
  }

  // Hero Section - REDUCED SIZE
  .hero-section {
    text-align: center;
    padding: 3rem 2rem 2rem;
    background: linear-gradient(
      180deg,
      rgba(212, 175, 55, 0.05) 0%,
      transparent 100%
    );

    .icon-wrapper {
      margin-bottom: 1.5rem;
      
      svg {
        filter: drop-shadow(0 0 20px rgba(212, 175, 55, 0.5));
      }
    }

    .main-title {
      font-size: 3rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: 0.8rem;
      font-weight: 400;

      .highlight {
        color: #d4af37;
        font-weight: 500;
      }
    }

    .subtitle {
      font-size: 1.4rem;
      color: rgba(255, 255, 255, 0.7);
      font-weight: 300;
    }
  }

  // Mission Section - REDUCED
  .mission-section {
    background-color: rgba(26, 26, 26, 0.4);
    padding: 3rem 2rem;

    .mission-text {
      font-size: 1.3rem;
      line-height: 1.8;
      color: rgba(255, 255, 255, 0.85);
      text-align: center;
      max-width: 900px;
      margin: 0 auto 1.5rem;

      &:last-child {
        margin-bottom: 0;
      }
    }
  }

  // University Section
  .university-section {
    .university-info {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 3rem;
      align-items: center;
      background-color: rgba(26, 26, 26, 0.6);
      border: 1px solid rgba(212, 175, 55, 0.2);
      border-radius: 16px;
      padding: 3rem;

      .university-logo {
        .logo-placeholder {
          width: 120px;
          height: 120px;
          background: linear-gradient(135deg, rgba(212, 175, 55, 0.2), rgba(212, 175, 55, 0.1));
          border: 2px solid rgba(212, 175, 55, 0.3);
          border-radius: 50%;
          display: flex;
          align-items: center;
          justify-content: center;

          .university-initial {
            font-size: 2.5rem;
            color: #d4af37;
            font-weight: 600;
          }
        }
      }

      .university-details {
        h3 {
          font-size: 2rem;
          color: #d4af37;
          margin-bottom: 0.8rem;
          font-weight: 400;
        }

        .program {
          font-size: 1.3rem;
          color: rgba(255, 255, 255, 0.9);
          margin-bottom: 0.5rem;
          font-weight: 500;
        }

        .project-type {
          font-size: 1.15rem;
          color: rgba(212, 175, 55, 0.8);
          margin-bottom: 1.5rem;
          font-style: italic;
        }

        .description {
          font-size: 1.2rem;
          line-height: 1.7;
          color: rgba(255, 255, 255, 0.8);
        }
      }
    }
  }

  // Team Section
  .team-section {
    background-color: rgba(26, 26, 26, 0.3);

    .team-intro {
      text-align: center;
      font-size: 1.25rem;
      color: rgba(255, 255, 255, 0.75);
      margin-bottom: 3rem;
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      max-width: 1000px;
      margin: 0 auto;

      .team-card {
        background-color: rgba(26, 26, 26, 0.6);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s;

        &:hover {
          transform: translateY(-5px);
          border-color: rgba(212, 175, 55, 0.5);
          box-shadow: 0 10px 30px rgba(212, 175, 55, 0.2);
        }

        .member-image {
          margin-bottom: 1.5rem;

          .image-placeholder {
            width: 120px;
            height: 120px;
            margin: 0 auto;
            background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(212, 175, 55, 0.05));
            border: 2px solid rgba(212, 175, 55, 0.3);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
          }
        }

        .member-name {
          font-size: 1.5rem;
          color: #d4af37;
          margin-bottom: 0.5rem;
          font-weight: 400;
        }

        .member-role {
          font-size: 1.15rem;
          color: rgba(255, 255, 255, 0.75);
        }
      }
    }
  }

  // Features Section
  .features-section {
    background-color: rgba(26, 26, 26, 0.4);

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;

      .feature-card {
        background-color: rgba(26, 26, 26, 0.6);
        border: 1px solid rgba(212, 175, 55, 0.2);
        border-radius: 12px;
        padding: 2rem;
        transition: all 0.3s;

        &:hover {
